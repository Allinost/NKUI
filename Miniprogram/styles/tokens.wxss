/* NKUI Design Tokens - Reusable WXSS classes */
/* Import this file with: @import '../../styles/_tokens.wxss'; */

/* === Utility Classes === */

/* Colors */
.nk-color-primary { background: #2196F3; color: #fff; border-color: #2196F3; }
.nk-color-success { background: #4CAF50; color: #fff; border-color: #4CAF50; }
.nk-color-warning { background: #FF9800; color: #fff; border-color: #FF9800; }
.nk-color-danger  { background: #F44336; color: #fff; border-color: #F44336; }
.nk-color-neutral { background: #424242; color: #fff; border-color: #424242; }

/* Text Colors */
.nk-text-primary { color: #2196F3; }
.nk-text-success { color: #4CAF50; }
.nk-text-warning { color: #FF9800; }
.nk-text-danger  { color: #F44336; }
.nk-text-neutral { color: #424242; }

/* Border Colors */
.nk-border-primary { border-color: #2196F3; }
.nk-border-success { border-color: #4CAF50; }
.nk-border-warning { border-color: #FF9800; }
.nk-border-danger  { border-color: #F44336; }

/* Font Sizes */
.nk-fs-xs  { font-size: 20rpx; }
.nk-fs-sm  { font-size: 24rpx; }
.nk-fs-base { font-size: 28rpx; }
.nk-fs-lg  { font-size: 32rpx; }
.nk-fs-xl  { font-size: 40rpx; }
.nk-fs-2xl { font-size: 48rpx; }
.nk-fs-3xl { font-size: 64rpx; }

/* Spacing */
.nk-p-xs  { padding: 8rpx; }
.nk-p-sm  { padding: 16rpx; }
.nk-p-md  { padding: 24rpx; }
.nk-p-lg  { padding: 32rpx; }
.nk-p-xl  { padding: 48rpx; }

.nk-m-xs  { margin: 8rpx; }
.nk-m-sm  { margin: 16rpx; }
.nk-m-md  { margin: 24rpx; }
.nk-m-lg  { margin: 32rpx; }

/* Radius */
.nk-radius-sm  { border-radius: 8rpx; }
.nk-radius-md  { border-radius: 16rpx; }
.nk-radius-lg  { border-radius: 24rpx; }
.nk-radius-full { border-radius: 9999rpx; }

/* Opacity */
.nk-disabled { opacity: 0.38; }

/* Text */
.nk-text-center { text-align: center; }
.nk-text-left   { text-align: left; }
.nk-text-right  { text-align: right; }
.nk-font-medium { font-weight: 500; }
.nk-font-bold   { font-weight: 700; }

/* Flex */
.nk-flex      { display: flex; }
.nk-flex-col  { flex-direction: column; }
.nk-flex-wrap { flex-wrap: wrap; }
.nk-items-center { align-items: center; }
.nk-justify-center { justify-content: center; }
.nk-flex-1    { flex: 1; }
.nk-gap-xs    { gap: 8rpx; }
.nk-gap-sm    { gap: 16rpx; }
.nk-gap-md    { gap: 24rpx; }
.nk-gap-lg    { gap: 32rpx; }

@import '../../styles/tokens.wxss';

.nk-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 96rpx 48rpx; text-align: center;
}

.nk-empty__image { margin-bottom: 32rpx; line-height: 0; }

.nk-empty__description {
  margin: 0 0 32rpx;
  color: var(--nk-color-neutral-500, #9E9E9E);
  font-size: var(--nk-font-size-sm, 24rpx);
}

.nk-empty__actions { display: flex; gap: 16rpx; }

.nk-empty--sm { padding: 64rpx 48rpx; }
.nk-empty--lg { padding: 128rpx 48rpx; }

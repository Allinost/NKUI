@import '../../styles/tokens.wxss';

.nk-switch {
  display: inline-flex; align-items: center; gap: 16rpx;
}
.nk-switch--disabled { opacity: 0.38; }

.nk-switch__track {
  position: relative; display: flex; align-items: center;
  border-radius: 9999rpx; background: var(--nk-color-neutral-300, #E0E0E0);
  transition: background 0.2s;
}
.nk-switch--checked .nk-switch__track { background: var(--nk-color-primary-500, #2196F3); }

.nk-switch--sm .nk-switch__track { width: 56rpx; height: 32rpx; }
.nk-switch--md .nk-switch__track { width: 72rpx; height: 40rpx; }
.nk-switch--lg .nk-switch__track { width: 88rpx; height: 48rpx; }

.nk-switch__thumb {
  display: block; border-radius: 50%; background: var(--nk-color-neutral-0, #FFFFFF);
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.15);
  transition: transform 0.2s;
}

.nk-switch--sm .nk-switch__thumb { width: 24rpx; height: 24rpx; margin: 0 4rpx; }
.nk-switch--md .nk-switch__thumb { width: 32rpx; height: 32rpx; margin: 0 4rpx; }
.nk-switch--lg .nk-switch__thumb { width: 40rpx; height: 40rpx; margin: 0 4rpx; }

.nk-switch--checked .nk-switch__thumb { transform: translateX(100%); }
.nk-switch--sm.nk-switch--checked .nk-switch__thumb { transform: translateX(24rpx); }
.nk-switch--md.nk-switch--checked .nk-switch__thumb { transform: translateX(32rpx); }
.nk-switch--lg.nk-switch--checked .nk-switch__thumb { transform: translateX(40rpx); }

.nk-switch__spinner {
  border: 4rpx solid rgba(255,255,255,0.4);
  border-top-color: #fff; border-radius: 50%;
  animation: nk-switch-spin 0.6s linear infinite;
}
.nk-switch--sm .nk-switch__spinner { width: 24rpx; height: 24rpx; margin: 0 4rpx; }
.nk-switch--md .nk-switch__spinner { width: 32rpx; height: 32rpx; margin: 0 4rpx; }
.nk-switch--lg .nk-switch__spinner { width: 40rpx; height: 40rpx; margin: 0 4rpx; }

.nk-switch__label { font-size: 28rpx; color: var(--nk-color-neutral-800, #424242); }

@keyframes nk-switch-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@import '../../styles/tokens.wxss';

.nk-popover { position: relative; display: inline-flex; }

.nk-popover__trigger { cursor: pointer; }

.nk-popover__panel {
  position: absolute; z-index: 999;
  background: var(--nk-color-neutral-0, #FFFFFF);
  border: 2rpx solid var(--nk-color-neutral-200, #EEEEEE);
  border-radius: 16rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  padding: 24rpx 32rpx; font-size: 24rpx;
  color: var(--nk-color-neutral-700, #616161);
}

.nk-popover__arrow {
  position: absolute; width: 16rpx; height: 16rpx;
  background: var(--nk-color-neutral-0, #FFFFFF);
  border: 2rpx solid var(--nk-color-neutral-200, #EEEEEE);
  transform: rotate(45deg); z-index: -1;
}

.nk-popover__content { position: relative; }

.nk-popover__mask {
  position: fixed; inset: 0; z-index: 998;
}

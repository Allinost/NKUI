@import '/styles/tokens.wxss';

.nk-product-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: var(--nk-color-neutral-0, #FFFFFF);
  border-radius: 16rpx;
  border: 2rpx solid var(--nk-color-neutral-200, #EEEEEE);
}

.nk-product-card--clickable:active {
  background: var(--nk-color-neutral-50, #FAFAFA);
}

.nk-product-card__cover {
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
  border-radius: 8rpx;
  overflow: hidden;
  background: var(--nk-color-neutral-100, #F5F5F5);
}

.nk-product-card__image {
  width: 100%;
  height: 100%;
}

.nk-product-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--nk-color-neutral-400, #BDBDBD);
}

.nk-product-card__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
  gap: 16rpx;
}

.nk-product-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.nk-product-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--nk-color-neutral-900, #212121);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.nk-product-card__status {
  font-size: 20rpx;
  color: var(--nk-color-primary-500, #2196F3);
  background: var(--nk-color-primary-50, #E3F2FD);
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.nk-product-card__description {
  font-size: 24rpx;
  color: var(--nk-color-neutral-500, #9E9E9E);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.nk-product-card__stock {
  font-size: 20rpx;
  color: var(--nk-color-neutral-400, #BDBDBD);
  white-space: nowrap;
  flex-shrink: 0;
}

.nk-product-card__tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.nk-product-card__tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  background: var(--nk-color-neutral-100, #F5F5F5);
  color: var(--nk-color-neutral-600, #757575);
  border-radius: 6rpx;
  white-space: nowrap;
}

.nk-product-card__price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--nk-color-error, #F44336);
  white-space: nowrap;
  flex-shrink: 0;
}

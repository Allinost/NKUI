@import '../../styles/tokens.wxss';

.nk-tooltip { position: relative; display: inline-flex; }

.nk-tooltip__content {
  position: absolute; padding: 12rpx 20rpx;
  background: var(--nk-color-neutral-900, #212121); color: #FFFFFF;
  font-size: 24rpx; border-radius: 8rpx;
  white-space: nowrap; pointer-events: none; z-index: 1000;
  line-height: 1.4; max-width: 400rpx;
  word-break: break-all;
}

.nk-tooltip__arrow {
  position: absolute; width: 16rpx; height: 16rpx;
  background: var(--nk-color-neutral-900, #212121);
  transform: rotate(45deg); z-index: -1;
}

/* Placement: top */
.nk-tooltip--top { bottom: calc(100% + 12rpx); left: 50%; transform: translateX(-50%); }
.nk-tooltip--top .nk-tooltip__arrow { bottom: -8rpx; left: 50%; transform: translateX(-50%) rotate(45deg); }

/* Placement: bottom */
.nk-tooltip--bottom { top: calc(100% + 12rpx); left: 50%; transform: translateX(-50%); }
.nk-tooltip--bottom .nk-tooltip__arrow { top: -8rpx; left: 50%; transform: translateX(-50%) rotate(45deg); }

/* Placement: left */
.nk-tooltip--left { right: calc(100% + 12rpx); top: 50%; transform: translateY(-50%); }
.nk-tooltip--left .nk-tooltip__arrow { right: -8rpx; top: 50%; transform: translateY(-50%) rotate(45deg); }

/* Placement: right */
.nk-tooltip--right { left: calc(100% + 12rpx); top: 50%; transform: translateY(-50%); }
.nk-tooltip--right .nk-tooltip__arrow { left: -8rpx; top: 50%; transform: translateY(-50%) rotate(45deg); }

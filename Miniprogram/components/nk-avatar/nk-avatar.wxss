@import '../../styles/tokens.wxss';

.nk-avatar {
  display: inline-flex; align-items: center; justify-content: center;
  overflow: hidden; background: var(--nk-color-primary-100, #BBDEFB); color: var(--nk-color-primary-700, #1976D2); flex-shrink: 0;
  vertical-align: middle;
}
.nk-avatar--circle { border-radius: 50%; }
.nk-avatar--square { border-radius: 16rpx; }

.nk-avatar__img { width: 100%; height: 100%; object-fit: cover; }

.nk-avatar__text { font-weight: 700; line-height: 1; }

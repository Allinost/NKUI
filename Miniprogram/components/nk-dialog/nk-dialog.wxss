@import '../../styles/tokens.wxss';

.nk-dialog__overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.45);
  display: flex; align-items: center; justify-content: center; z-index: 1000;
}

.nk-dialog {
  width: 600rpx; max-width: 85vw; background: var(--nk-color-neutral-0, #FFFFFF);
  border-radius: 24rpx; box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.15);
  display: flex; flex-direction: column;
}

.nk-dialog__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 48rpx; border-bottom: 2rpx solid var(--nk-color-neutral-100, #F5F5F5);
}
.nk-dialog__title { font-size: 32rpx; font-weight: 600; color: var(--nk-color-neutral-900, #212121); }
.nk-dialog__close { color: var(--nk-color-neutral-400, #BDBDBD); font-size: 28rpx; padding: 8rpx; }

.nk-dialog__body { padding: 48rpx; color: var(--nk-color-neutral-700, #616161); font-size: 28rpx; line-height: 1.6; }
.nk-dialog__footer {
  display: flex; justify-content: flex-end; gap: 16rpx;
  padding: 32rpx 48rpx; border-top: 2rpx solid var(--nk-color-neutral-100, #F5F5F5);
}

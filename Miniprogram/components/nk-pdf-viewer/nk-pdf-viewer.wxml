<view class="nk-pdf-viewer" style="width:{{width}};height:{{height}}">
  <web-view wx:if="{{isWebViewSrc}}" src="{{src}}" />
  <view wx:else class="nk-pdf-viewer__fallback">
    <view class="nk-pdf-viewer__icon">
      <image src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='40' height='40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 1h5.5L13 4.5V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zm6.5 4H10V2.5L10.5 5zM6 7.5A.5.5 0 0 1 6.5 7h3a.5.5 0 0 1 0 1h-3a.5.5 0 0 1-.5-.5zM6 9.5A.5.5 0 0 1 6.5 9h3a.5.5 0 0 1 0 1h-3a.5.5 0 0 1-.5-.5zM6 11.5A.5.5 0 0 1 6.5 11h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5z' fill='%239E9E9E'/%3E%3C/svg%3E" style="width:80rpx;height:80rpx" />
    </view>
    <text class="nk-pdf-viewer__text">PDF 预览需要使用 web-view 组件</text>
    <text class="nk-pdf-viewer__url">{{src}}</text>
  </view>
</view>

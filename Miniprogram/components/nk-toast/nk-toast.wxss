@import '../../styles/tokens.wxss';

.nk-toast__overlay {
  position: fixed; inset: 0;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none; z-index: 2000;
}

.nk-toast {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 48rpx; border-radius: 16rpx;
  font-size: 28rpx; line-height: 1.5;
  max-width: 600rpx; word-break: break-all;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.nk-toast--info { background: var(--nk-color-neutral-900, #212121); color: #FFFFFF; }
.nk-toast--success { background: #4CAF50; color: #FFFFFF; }
.nk-toast--warning { background: #FF9800; color: #FFFFFF; }
.nk-toast--error { background: #F44336; color: #FFFFFF; }

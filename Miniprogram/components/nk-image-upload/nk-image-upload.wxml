<view class="nk-image-upload nk-image-upload--{{size}} {{disabled ? 'nk-image-upload--disabled' : ''}}">
  <view class="nk-image-upload__list nk-image-upload__list--{{listType}}">
    <view
      wx:for="{{imageList}}" wx:key="index"
      class="nk-image-upload__item"
      data-index="{{index}}" bindtap="preview"
    >
      <image class="nk-image-upload__img" src="{{item}}" mode="aspectFill" />
      <view class="nk-image-upload__item-mask">
        <text class="nk-image-upload__item-remove" data-index="{{index}}" bindtap="remove">✕</text>
      </view>
    </view>
    <view wx:if="{{imageList.length < maxCount}}" class="nk-image-upload__item nk-image-upload__item--add" bindtap="onChooseImage">
      <text class="nk-image-upload__add-icon">+</text>
      <text class="nk-image-upload__add-text">上传</text>
    </view>
  </view>
</view>

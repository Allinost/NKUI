@import '../../styles/tokens.wxss';

.nk-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-weight: 500;
  line-height: 1.2;
  white-space: nowrap;
  box-sizing: border-box;
  text-align: center;
  transition: opacity 0.15s;
}

.nk-btn::after { display: none; }

.nk-btn--block { width: 100%; }
.nk-btn--round { border-radius: 9999rpx; }
.nk-btn--disabled { opacity: 0.38; }

/* Sizes */
.nk-btn--sm { height: 56rpx; font-size: 24rpx; padding: 0 24rpx; border-radius: 12rpx; }
.nk-btn--md { height: 72rpx; font-size: 28rpx; padding: 0 32rpx; border-radius: 14rpx; }
.nk-btn--lg { height: 88rpx; font-size: 32rpx; padding: 0 48rpx; border-radius: 18rpx; }

/* Solid */
.nk-btn--solid.nk-btn--primary { background: #2196F3; color: #fff; border-color: #2196F3; }
.nk-btn--solid.nk-btn--success { background: #4CAF50; color: #fff; border-color: #4CAF50; }
.nk-btn--solid.nk-btn--warning { background: #FF9800; color: #fff; border-color: #FF9800; }
.nk-btn--solid.nk-btn--danger  { background: #F44336; color: #fff; border-color: #F44336; }
.nk-btn--solid.nk-btn--neutral { background: #424242; color: #fff; border-color: #424242; }

/* Outline */
.nk-btn--outline.nk-btn--primary { background: transparent; color: #2196F3; border-color: #2196F3; }
.nk-btn--outline.nk-btn--success { background: transparent; color: #4CAF50; border-color: #4CAF50; }
.nk-btn--outline.nk-btn--warning { background: transparent; color: #FF9800; border-color: #FF9800; }
.nk-btn--outline.nk-btn--danger  { background: transparent; color: #F44336; border-color: #F44336; }
.nk-btn--outline.nk-btn--neutral { background: transparent; color: #424242; border-color: #424242; }

/* Ghost */
.nk-btn--ghost.nk-btn--primary { background: transparent; color: #2196F3; border-color: transparent; }
.nk-btn--ghost.nk-btn--success { background: transparent; color: #4CAF50; border-color: transparent; }
.nk-btn--ghost.nk-btn--warning { background: transparent; color: #FF9800; border-color: transparent; }
.nk-btn--ghost.nk-btn--danger  { background: transparent; color: #F44336; border-color: transparent; }
.nk-btn--ghost.nk-btn--neutral { background: transparent; color: #424242; border-color: transparent; }

/* Text */
.nk-btn--text { background: transparent; border-color: transparent; padding: 0 8rpx; }
.nk-btn--text.nk-btn--primary { color: #2196F3; }
.nk-btn--text.nk-btn--success { color: #4CAF50; }
.nk-btn--text.nk-btn--warning { color: #FF9800; }
.nk-btn--text.nk-btn--danger  { color: #F44336; }
.nk-btn--text.nk-btn--neutral { color: #424242; }

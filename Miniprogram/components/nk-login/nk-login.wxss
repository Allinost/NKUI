@import '/styles/tokens.wxss';

.nk-login {
  display: flex;
  flex-direction: column;
}

.nk-login--card {
  background: var(--nk-color-neutral-0, #FFFFFF);
  border: 2rpx solid var(--nk-color-neutral-200, #EEEEEE);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.nk-login--plain {
  background: transparent;
  border: none;
  border-radius: 0;
  box-shadow: none;
}

.nk-login--sm { width: 640rpx; padding: 40rpx; gap: 24rpx; }
.nk-login--md { width: 760rpx; padding: 56rpx; gap: 32rpx; }
.nk-login--lg { width: 880rpx; padding: 72rpx; gap: 40rpx; }

.nk-login--sm .nk-login__title { font-size: 32rpx; }
.nk-login--md .nk-login__title { font-size: 40rpx; }
.nk-login--lg .nk-login__title { font-size: 48rpx; }
.nk-login--sm .nk-login__subtitle { font-size: 20rpx; }
.nk-login--md .nk-login__subtitle { font-size: 24rpx; }
.nk-login--lg .nk-login__subtitle { font-size: 28rpx; }

.nk-login__header {
  text-align: center;
}

.nk-login__title {
  font-weight: 600;
  color: var(--nk-color-neutral-900, #212121);
}

.nk-login__subtitle {
  margin-top: 8rpx;
  color: var(--nk-color-neutral-500, #9E9E9E);
}

.nk-login__form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.nk-login__field {
  display: flex;
  flex-direction: column;
}

.nk-login__actions {
  display: flex;
  flex-direction: column;
}

.nk-login__footer {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

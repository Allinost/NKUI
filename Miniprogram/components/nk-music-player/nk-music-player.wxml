<view class="nk-music-player nk-music-player--{{size}}">
  <view class="nk-music-player__body" catchtap="togglePlay">
    <view wx:if="{{cover || size !== 'sm'}}" class="nk-music-player__cover">
      <image wx:if="{{cover}}" class="nk-music-player__cover-img" src="{{cover}}" mode="aspectFill" />
      <view wx:else class="nk-music-player__cover-placeholder">
        <image src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='24' height='24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M6 13c0 1.105-1.12 2-2.5 2S1 14.105 1 13c0-1.104 1.12-2 2.5-2s2.5.896 2.5 2zm9-10v7c0 1.105-1.12 2-2.5 2S10 11.105 10 10c0-1.104 1.12-2 2.5-2s2.5.896 2.5 2V5.372L6 6.8v5.028C6 12.933 4.88 14 3.5 14S1 12.933 1 11.5C1 10.067 2.12 9 3.5 9s2.5 1.067 2.5 2.5V3.799a.5.5 0 0 1 .425-.492l8-1.466A.5.5 0 0 1 15 2.33z' fill='%232196F3'/%3E%3C/svg%3E" style="width:24px;height:24px" />
      </view>
    </view>
    <view class="nk-music-player__info">
      <view wx:if="{{title}}" class="nk-music-player__title">{{title}}</view>
      <view wx:if="{{artist}}" class="nk-music-player__artist">{{artist}}</view>
      <view wx:if="{{duration}}" class="nk-music-player__time">{{formatTime(currentTime)}} / {{formatTime(duration)}}</view>
    </view>
    <view class="nk-music-player__controls">
      <view class="nk-music-player__btn" catchtap="prevTrack" data-disabled="{{!prevEnabled}}">
        <image src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='16' height='16' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3.5 1a.5.5 0 0 1 .5.5V7l6-5.5v11L4 9v5.5a.5.5 0 0 1-1 0v-13A.5.5 0 0 1 3.5 1zm8 0a.5.5 0 0 1 .5.5v13a.5.5 0 0 1-1 0v-13a.5.5 0 0 1 .5-.5z' fill='%23616161'/%3E%3C/svg%3E" style="width:16px;height:16px" />
      </view>
      <view class="nk-music-player__btn nk-music-player__btn--play" catchtap="togglePlay">
        <image wx:if="{{playing}}" src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='20' height='20' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M5 3a1 1 0 0 1 1 1v8a1 1 0 0 1-2 0V4a1 1 0 0 1 1-1zm6 0a1 1 0 0 1 1 1v8a1 1 0 0 1-2 0V4a1 1 0 0 1 1-1z' fill='white'/%3E%3C/svg%3E" style="width:20px;height:20px" />
        <image wx:else src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='20' height='20' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11.596 8.697l-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z' fill='white'/%3E%3C/svg%3E" style="width:20px;height:20px" />
      </view>
      <view class="nk-music-player__btn" catchtap="nextTrack" data-disabled="{{!nextEnabled}}">
        <image src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='16' height='16' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M12.5 1a.5.5 0 0 0-.5.5V7l-6-5.5v11l6-5.5v5.5a.5.5 0 0 0 1 0v-13A.5.5 0 0 0 12.5 1zM3.5 1a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 1 0v-13A.5.5 0 0 0 3.5 1z' fill='%23616161'/%3E%3C/svg%3E" style="width:16px;height:16px" />
      </view>
    </view>
  </view>
  <view wx:if="{{duration && size !== 'sm'}}" class="nk-music-player__progress">
    <slider class="nk-music-player__slider" min="0" max="{{duration}}" value="{{currentTime}}" step="0.1" bindchange="onSliderChange" />
  </view>
  <audio wx:if="{{src}}" src="{{src}}" binderror="onError" />
</view>

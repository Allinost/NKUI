@import '/styles/tokens.wxss';

.nk-todo-task {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--nk-color-neutral-0, #FFFFFF);
  border-radius: 8rpx;
}

.nk-todo-task:active {
  background: var(--nk-color-neutral-50, #FAFAFA);
}

.nk-todo-task--done {
  opacity: 0.6;
}
.nk-todo-task--done .nk-todo-task__title {
  text-decoration: line-through;
  color: var(--nk-color-neutral-400, #BDBDBD);
}

.nk-todo-task--sm .nk-todo-task__row { min-height: 64rpx; }
.nk-todo-task--lg .nk-todo-task__row { min-height: 48rpx; }

.nk-todo-task__checkbox {
  flex-shrink: 0;
  padding-top: 4rpx;
}

.nk-todo-task__check-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 4rpx solid var(--nk-color-neutral-300, #E0E0E0);
  color: transparent;
  box-sizing: border-box;
}
.nk-todo-task__check-mark {
  font-size: 20rpx;
  line-height: 1;
}
.nk-todo-task__check-icon--checked {
  background: var(--nk-color-primary-500, #2196F3);
  border-color: var(--nk-color-primary-500, #2196F3);
  color: #fff;
}

.nk-todo-task__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.nk-todo-task__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.nk-todo-task__row--meta { margin-top: 4rpx; }

.nk-todo-task__title-area {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.nk-todo-task__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.nk-todo-task__title {
  font-size: 28rpx;
  color: var(--nk-color-neutral-900, #212121);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nk-todo-task__due {
  font-size: 20rpx;
  color: var(--nk-color-neutral-400, #BDBDBD);
  white-space: nowrap;
  flex-shrink: 0;
}

.nk-todo-task__notes {
  font-size: 24rpx;
  color: var(--nk-color-neutral-500, #9E9E9E);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.nk-todo-task__meta-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.nk-todo-task__repeat,
.nk-todo-task__reminder {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: var(--nk-color-neutral-400, #BDBDBD);
  white-space: nowrap;
}

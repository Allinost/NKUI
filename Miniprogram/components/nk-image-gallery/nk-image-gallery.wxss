@import '../../styles/tokens.wxss';

.nk-image-gallery {
  display: grid;
  overflow: hidden;
  border-radius: 16rpx;
}
.nk-image-gallery__item {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 8rpx;
  cursor: pointer;
}
.nk-image-gallery__img {
  width: 100%;
  height: 100%;
  display: block;
}
.nk-image-gallery__more {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
}

.nk-image-gallery__preview-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.85);
}
.nk-image-gallery__preview-img {
  max-width: 90vw;
  max-height: 90vh;
  border-radius: 8rpx;
}
.nk-image-gallery__preview-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.15);
}
.nk-image-gallery__preview-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.15);
}
.nk-image-gallery__preview-nav--prev { left: 32rpx; }
.nk-image-gallery__preview-nav--next { right: 32rpx; }
.nk-image-gallery__preview-counter {
  position: absolute;
  bottom: 32rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 8rpx 24rpx;
  border-radius: 9999rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 24rpx;
}

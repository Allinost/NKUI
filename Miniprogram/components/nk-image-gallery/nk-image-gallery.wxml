<view class="nk-image-gallery" style="grid-template-columns:repeat({{columns}},1fr);gap:{{gap}}rpx">
  <view
    wx:for="{{resolvedImages}}"
    wx:key="index"
    class="nk-image-gallery__item {{maxCount && index >= maxCount ? 'nk-image-gallery__item--more' : ''}}"
    catchtap="openPreview"
    data-index="{{index}}"
  >
    <image class="nk-image-gallery__img" src="{{item.url}}" mode="aspectFill" lazy-load />
    <view wx:if="{{maxCount && index === maxCount - 1 && resolvedImages.length > maxCount}}" class="nk-image-gallery__more">
      +{{resolvedImages.length - maxCount}}
    </view>
  </view>
</view>

<view wx:if="{{previewVisible}}" class="nk-image-gallery__preview-mask" catchtap="closePreview">
  <view class="nk-image-gallery__preview-close" catchtap="closePreview">
    <image src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='20' height='20' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z' fill='white'/%3E%3C/svg%3E" style="width:20px;height:20px" />
  </view>
  <view
    wx:if="{{resolvedImages.length > 1}}"
    class="nk-image-gallery__preview-nav nk-image-gallery__preview-nav--prev"
    catchtap="prevImage"
  >
    <image src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='24' height='24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill-rule='evenodd' d='M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z' fill='white'/%3E%3C/svg%3E" style="width:24px;height:24px" />
  </view>
  <view
    wx:if="{{resolvedImages.length > 1}}"
    class="nk-image-gallery__preview-nav nk-image-gallery__preview-nav--next"
    catchtap="nextImage"
  >
    <image src="data:image/svg+xml,%3Csvg viewBox='0 0 16 16' width='24' height='24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill-rule='evenodd' d='M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z' fill='white'/%3E%3C/svg%3E" style="width:24px;height:24px" />
  </view>
  <image class="nk-image-gallery__preview-img" src="{{resolvedImages[previewIndex].url}}" mode="widthFix" />
  <view class="nk-image-gallery__preview-counter">{{previewIndex + 1}} / {{resolvedImages.length}}</view>
</view>

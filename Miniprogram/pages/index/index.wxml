<view class="page">
  <view class="demo-section">
    <text class="title">Button 按钮</text>
    <view class="demo-row">
      <nk-button wx:for="{{types}}" wx:key="item" type="{{item}}">{{item}}</nk-button>
      <nk-button type="neutral">neutral</nk-button>
    </view>
    <view class="demo-row">
      <nk-button wx:for="{{types}}" wx:key="item" type="{{item}}" variant="outline">{{item}}</nk-button>
    </view>
    <view class="demo-row">
      <nk-button wx:for="{{types}}" wx:key="item" type="{{item}}" variant="ghost">{{item}}</nk-button>
    </view>
    <view class="demo-row">
      <nk-button type="primary" variant="text">Text</nk-button>
      <nk-button type="danger" variant="text">Delete</nk-button>
    </view>
    <view class="demo-row">
      <nk-button size="sm">Small</nk-button>
      <nk-button size="md">Medium</nk-button>
      <nk-button size="lg">Large</nk-button>
    </view>
    <view class="demo-row">
      <nk-button loading>Loading</nk-button>
      <nk-button disabled>Disabled</nk-button>
      <nk-button round>Round</nk-button>
      <nk-button block>Block</nk-button>
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Input 输入框</text>
    <nk-input placeholder="Basic input" />
    <nk-input placeholder="With clear" clearable />
    <nk-input placeholder="With label" label="用户名" />
    <nk-input placeholder="With error" error="请输入有效内容" />
    <nk-input placeholder="Disabled" disabled />
  </view>

  <view class="demo-section">
    <text class="title">Tag 标签</text>
    <view class="demo-row">
      <nk-tag wx:for="{{types}}" wx:key="item" type="{{item}}">{{item}}</nk-tag>
    </view>
    <view class="demo-row">
      <nk-tag wx:for="{{types}}" wx:key="item" type="{{item}}" variant="solid">{{item}}</nk-tag>
    </view>
    <view class="demo-row">
      <nk-tag wx:for="{{types}}" wx:key="item" type="{{item}}" variant="outline">{{item}}</nk-tag>
    </view>
    <view class="demo-row">
      <nk-tag closable>Closable</nk-tag>
      <nk-tag round>Round</nk-tag>
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Badge 徽标</text>
    <view class="demo-row">
      <nk-badge variant="dot"><nk-button size="sm">Dot</nk-button></nk-badge>
      <nk-badge variant="count" value="5"><nk-button size="sm">Count</nk-button></nk-badge>
      <nk-badge variant="count" value="100"><nk-button size="sm">99+</nk-button></nk-badge>
      <nk-badge variant="text" value="new"><nk-button size="sm">Text</nk-button></nk-badge>
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Switch 开关</text>
    <view class="demo-row">
      <nk-switch />
      <nk-switch label="With label" />
      <nk-switch size="sm" />
      <nk-switch size="lg" />
      <nk-switch disabled />
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Checkbox & Radio</text>
    <view class="demo-row">
      <nk-checkbox label="Checkbox" />
      <nk-checkbox label="Disabled" disabled />
    </view>
    <view class="demo-row">
      <nk-radio label="Radio A" />
      <nk-radio label="Radio B" />
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Select 选择器</text>
    <nk-select options="{{selectOptions}}" placeholder="请选择" />
  </view>

  <view class="demo-section">
    <text class="title">Avatar 头像</text>
    <view class="demo-row">
      <nk-avatar text="张" />
      <nk-avatar text="李" size="lg" />
      <nk-avatar variant="square" text="NK" />
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Card 卡片</text>
    <view class="demo-row" style="flex-direction:column">
      <nk-card variant="outlined"><text>Outlined card content</text></nk-card>
      <nk-card variant="elevated"><text>Elevated card content</text></nk-card>
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Divider</text>
    <text>上方内容</text>
    <nk-divider />
    <text>下方内容</text>
    <nk-divider dashed />
  </view>

  <view class="demo-section">
    <text class="title">Progress 进度条</text>
    <nk-progress percent="65" />
    <nk-progress percent="100" status="success" />
    <nk-progress percent="45" status="exception" />
    <nk-progress percent="30" striped />
  </view>

  <view class="demo-section">
    <text class="title">Loading 加载</text>
    <view class="demo-row">
      <nk-loading size="sm" />
      <nk-loading size="md" />
      <nk-loading size="lg" />
      <nk-loading variant="bar" />
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Skeleton 骨架屏</text>
    <nk-skeleton variant="paragraph" rows="3" />
    <nk-skeleton variant="avatar" size="lg" />
    <nk-skeleton variant="image" height="300rpx" />
  </view>

  <view class="demo-section">
    <text class="title">Empty 空状态</text>
    <nk-empty description="暂无数据" />
  </view>

  <view class="demo-section">
    <text class="title">Tabs 标签页</text>
    <nk-tabs items="{{tabItems}}" variant="line" bind:change="onTabChange">
      <view>内容 1</view>
    </nk-tabs>
    <nk-tabs items="{{tabItems}}" variant="card" />
    <nk-tabs items="{{tabItems}}" variant="segment" />
  </view>

  <view class="demo-section">
    <text class="title">Breadcrumb 面包屑</text>
    <nk-breadcrumb items="{{breadcrumbItems}}" />
  </view>

  <view class="demo-section">
    <text class="title">Pagination 分页</text>
    <nk-pagination total="100" pageSize="10" bind:change="onPageChange" />
  </view>

  <view class="demo-section">
    <text class="title">Tooltip 文字提示</text>
    <view class="demo-row">
      <nk-tooltip content="顶部提示" placement="top"><nk-button size="sm">上</nk-button></nk-tooltip>
      <nk-tooltip content="底部提示" placement="bottom"><nk-button size="sm">下</nk-button></nk-tooltip>
      <nk-tooltip content="左侧提示" placement="left"><nk-button size="sm">左</nk-button></nk-tooltip>
      <nk-tooltip content="右侧提示" placement="right"><nk-button size="sm">右</nk-button></nk-tooltip>
    </view>
  </view>

  <view class="demo-section">
    <text class="title">Popover 弹出框</text>
    <nk-popover content="这是一个 Popover 弹出框">
      <view slot="reference"><nk-button size="sm">点击打开</nk-button></view>
    </nk-popover>
  </view>

  <view class="demo-section">
    <text class="title">Drawer 抽屉</text>
    <nk-button bind:click="openDrawer">打开抽屉</nk-button>
    <nk-drawer visible="{{drawerVisible}}" title="抽屉标题" bind:close="closeDrawer">
      <text>这是抽屉内容</text>
    </nk-drawer>
  </view>

  <view class="demo-section">
    <text class="title">Toast 消息提示</text>
    <view class="demo-row">
      <nk-button data-type="info" bind:click="showToast">Info</nk-button>
      <nk-button data-type="success" bind:click="showToast">Success</nk-button>
      <nk-button data-type="warning" bind:click="showToast">Warning</nk-button>
      <nk-button data-type="error" bind:click="showToast">Error</nk-button>
    </view>
    <nk-toast id="toast" />
  </view>

  <view class="demo-section">
    <text class="title">Dialog 对话框</text>
    <nk-button bind:click="openDialog">Open Dialog</nk-button>
    <nk-dialog id="dialog" title="确认操作">
      <text>确定要执行此操作吗？</text>
    </nk-dialog>
  </view>

  <view class="demo-section">
    <text class="title">ProfileCard 名片卡</text>
    <nk-profile-card name="张三" title="高级工程师" description="专注于前端开发与设计系统" />
  </view>

  <view class="demo-section">
    <text class="title">TopNav 顶部菜单栏</text>
    <nk-top-nav items="{{navItems}}" logo="NKUI" />
  </view>

  <view class="demo-section">
    <text class="title">BottomTab 底部导航</text>
    <nk-bottom-tab items="{{bottomTabItems}}" />
  </view>

  <view class="demo-section">
    <text class="title">Calendar 日历</text>
    <nk-calendar />
  </view>

  <view class="demo-section">
    <text class="title">FileUpload 文件上传</text>
    <view style="margin-bottom:16rpx"><nk-file-upload multiple variant="button" /></view>
    <nk-file-upload multiple variant="drag" />
  </view>

  <view class="demo-section">
    <text class="title">ImageUpload 图片上传</text>
    <nk-image-upload imageList="{{images}}" />
  </view>
</view>

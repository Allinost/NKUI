@import '/styles/tokens.wxss';

.page { padding: 32rpx 0; }

.demo-section {
  margin: 32rpx 24rpx;
  padding: 32rpx;
  background: var(--nk-color-neutral-0, #FFFFFF);
  border-radius: 16rpx;
  border: 2rpx solid var(--nk-color-neutral-200, #EEEEEE);
}

.demo-section .title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
  color: var(--nk-color-neutral-900, #212121);
}

.demo-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 16rpx;
}
